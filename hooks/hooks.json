{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_instructions.py\"",
            "timeout": 10,
            "statusMessage": "Orchestrator instructions"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/ledger_guard_spawn.py\"",
            "timeout": 10,
            "statusMessage": "Ledger guard (spawn)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/ledger_guard_stop.py\"",
            "timeout": 10,
            "statusMessage": "Ledger guard (close)"
          }
        ]
      }
    ]
  }
}
